# Copier ce fichier en .env et remplir les valeurs

# Clé secrète Flask (générer avec : python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete

# URL PostgreSQL (Railway la fournit automatiquement en production)
# Format local : postgresql://user:password@localhost:5432/annuaire
DATABASE_URL=postgresql://postgres:password@localhost:5432/annuaire

# Environnement : development ou production
FLASK_ENV=development

# Compte administrateur créé au premier démarrage
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez-moi
ADMIN_EMAIL=admin@votre-domaine.fr
