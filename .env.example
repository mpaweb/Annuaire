# ══════════════════════════════════════════════════════
# Annuaire Neoedge — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════

# Clé secrète Flask — OBLIGATOIRE en production
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=remplacez-par-une-vraie-cle-secrete-generee

# Base de données
# SQLite (local)    : sqlite:///annuaire.db
# PostgreSQL        : postgresql://user:password@localhost:5432/annuaire
# Railway           : fourni automatiquement via DATABASE_URL
DATABASE_URL=sqlite:///annuaire.db

# Environnement : development ou production
# En production, les cookies sont forcés en HTTPS et SECRET_KEY est obligatoire
FLASK_ENV=development

# Compte administrateur (créé au premier démarrage uniquement)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe2024!
ADMIN_EMAIL=admin@votre-domaine.fr
